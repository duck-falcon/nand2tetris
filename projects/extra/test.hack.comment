0110000000000000 // A に keyboard のアドレスを入れる
1111110000010000 // D に keyboard からの取得値を入れる
0000000000000000 // A に RAM の先頭アドレスを入れる
1110001100001000 // RAM の先頭にDの値を書き出す(RAM の先頭 = keyboard で取得した値)
0100000000000000 // A に Screen のアドレスを入れる
1110110000010000 // D に A を書き出す
0000000000000001 // A を RAMの2番目に設定する(RAM の2番目 = 次に書き出すスクリーンのアドレス)
1110001100001000 // D を A のアドレスに書き出す
0000000000000000 // A を RAMの1番目に設定する (ジャンプ先)
1111110000010000 // D の値を A のアドレスからとってきて書き出す
0000000000000001 // A を RAM の2番目に設定する
1111110000100000 // A に RAM の 2番目の値を書き出す
1110001100001000 // D の値を A 指定のメモリに書き出す
1110110111100000 // A のアドレスを1足す
1110110000010000 // A を D に書き出す
0000000000000001 // A を RAM の2番目に設定する
1110001100001000 // RAM に D を書き出す
0000000000001000 // A のアドレスをジャンプ先のアドレスにする
1111000000000111 // 無条件ジャンプ 
